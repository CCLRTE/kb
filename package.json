{
  "name": "@cclrte/kb",
  "version": "0.1.0",
  "description": "A local-first Markdown knowledge-base CLI with auditable web capture and derived backlinks.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CCLRTE/kb.git"
  },
  "homepage": "https://github.com/CCLRTE/kb#readme",
  "bugs": {
    "url": "https://github.com/CCLRTE/kb/issues"
  },
  "keywords": [
    "knowledge-base",
    "markdown",
    "obsidian",
    "web-clipper",
    "backlinks",
    "local-first"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./capture": {
      "types": "./src/capture.ts",
      "import": "./dist/capture.js"
    },
    "./graph": {
      "types": "./src/graph.ts",
      "import": "./dist/graph.js"
    }
  },
  "bin": {
    "kb": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src/capture.ts",
    "src/cli.ts",
    "src/clip/acquire.ts",
    "src/clip/args.ts",
    "src/clip/assets.ts",
    "src/clip/bounded-byte-buffer.ts",
    "src/clip/capture.ts",
    "src/clip/cli.ts",
    "src/clip/cookies.ts",
    "src/clip/doctor.ts",
    "src/clip/extract.ts",
    "src/clip/lib.ts",
    "src/clip/media.ts",
    "src/clip/network-proxy.ts",
    "src/clip/network.ts",
    "src/clip/package-root.ts",
    "src/clip/persist.ts",
    "src/clip/platforms.ts",
    "src/clip/structured.ts",
    "src/clip/terminal.ts",
    "src/graph.ts",
    "src/index.ts",
    "src/init.ts",
    "src/vault.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun -e 'await (await import(\"node:fs/promises\")).rm(\"./dist\", { recursive: true, force: true })' && bun build ./src/index.ts ./src/capture.ts ./src/graph.ts ./src/cli.ts ./src/clip/defuddle-worker.ts --outdir ./dist --root ./src --target bun --format esm --splitting --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:package": "bun run ./scripts/package-smoke.ts",
    "check": "bun run typecheck && bun run test && bun run build && bun run test:package",
    "prepack": "bun run check"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "git+https://github.com/CCLRTE/sweet-cookie.git#81b63e11677bf73e2660493a48228d11812c5ee0",
    "agent-browser": "0.32.3",
    "defuddle": "0.19.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
