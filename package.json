{
  "name": "@cclrte/kb",
  "version": "0.3.3",
  "description": "A simple Markdown knowledge base for coding agents with local search, auditable capture, and derived backlinks.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hraness/kb.git"
  },
  "homepage": "https://github.com/hraness/kb#readme",
  "bugs": {
    "url": "https://github.com/hraness/kb/issues"
  },
  "keywords": [
    "knowledge-base",
    "markdown",
    "obsidian",
    "web-clipper",
    "backlinks",
    "semantic-search",
    "agent-memory",
    "local-first"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./browser-profiles": {
      "types": "./src/clip/browser-profiles.ts",
      "import": "./dist/clip/browser-profiles.js"
    },
    "./capture": {
      "types": "./src/capture.ts",
      "import": "./dist/capture.js"
    },
    "./clip/acquire": {
      "types": "./src/clip/acquire.ts",
      "import": "./dist/clip/acquire.js"
    },
    "./clip/args": {
      "types": "./src/clip/args.ts",
      "import": "./dist/clip/args.js"
    },
    "./clip/bounded-byte-buffer": {
      "types": "./src/clip/bounded-byte-buffer.ts",
      "import": "./dist/clip/bounded-byte-buffer.js"
    },
    "./clip/cli": {
      "types": "./src/clip/cli.ts",
      "import": "./dist/clip/cli.js"
    },
    "./clip/doctor": {
      "types": "./src/clip/doctor.ts",
      "import": "./dist/clip/doctor.js"
    },
    "./clip/network": {
      "types": "./src/clip/network.ts",
      "import": "./dist/clip/network.js"
    },
    "./clip/network-proxy": {
      "types": "./src/clip/network-proxy.ts",
      "import": "./dist/clip/network-proxy.js"
    },
    "./clip/persist": {
      "types": "./src/clip/persist.ts",
      "import": "./dist/clip/persist.js"
    },
    "./clip/terminal": {
      "types": "./src/clip/terminal.ts",
      "import": "./dist/clip/terminal.js"
    },
    "./graph": {
      "types": "./src/graph.ts",
      "import": "./dist/graph.js"
    },
    "./navigation": {
      "types": "./src/navigation.ts",
      "import": "./dist/navigation.js"
    },
    "./pdf": {
      "types": "./src/pdf.ts",
      "import": "./dist/pdf.js"
    },
    "./query": {
      "types": "./src/query.ts",
      "import": "./dist/query.js"
    },
    "./semantic": {
      "types": "./src/semantic.ts",
      "import": "./dist/semantic.js"
    }
  },
  "bin": {
    "kb": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src/capture.ts",
    "src/cli.ts",
    "src/clip/acquire.ts",
    "src/clip/args.ts",
    "src/clip/assets.ts",
    "src/clip/bounded-byte-buffer.ts",
    "src/clip/browser-profiles.ts",
    "src/clip/capture.ts",
    "src/clip/cli.ts",
    "src/clip/cookies.ts",
    "src/clip/doctor.ts",
    "src/clip/extract.ts",
    "src/clip/lib.ts",
    "src/clip/media.ts",
    "src/clip/network-proxy.ts",
    "src/clip/network.ts",
    "src/clip/package-root.ts",
    "src/clip/persist.ts",
    "src/clip/platforms.ts",
    "src/clip/structured.ts",
    "src/clip/terminal.ts",
    "src/graph.ts",
    "src/index.ts",
    "src/init.ts",
    "src/navigation.ts",
    "src/pdf.ts",
    "src/pdf/args.ts",
    "src/pdf/capture.ts",
    "src/pdf/cli.ts",
    "src/pdf/extract.ts",
    "src/pdf/layout.ts",
    "src/pdf/markdown.ts",
    "src/pdf/model.ts",
    "src/pdf/ocr.ts",
    "src/pdf/persist.ts",
    "src/pdf/source.ts",
    "src/pdf/tools.ts",
    "src/query.ts",
    "src/semantic.ts",
    "src/vault.ts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun -e 'await (await import(\"node:fs/promises\")).rm(\"./dist\", { recursive: true, force: true })' && bun build ./src/index.ts ./src/clip/browser-profiles.ts ./src/capture.ts ./src/clip/acquire.ts ./src/clip/args.ts ./src/clip/bounded-byte-buffer.ts ./src/clip/cli.ts ./src/clip/doctor.ts ./src/clip/network.ts ./src/clip/network-proxy.ts ./src/clip/persist.ts ./src/clip/terminal.ts ./src/graph.ts ./src/navigation.ts ./src/pdf.ts ./src/query.ts ./src/semantic.ts ./src/cli.ts ./src/clip/defuddle-worker.ts --outdir ./dist --root ./src --target bun --format esm --splitting --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:package": "bun run ./scripts/package-smoke.ts",
    "check": "bun run typecheck && bun run test && bun run build && bun run test:package",
    "prepack": "bun run check"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "git+https://github.com/hraness/sweet-cookie.git#81b63e11677bf73e2660493a48228d11812c5ee0",
    "@tobilu/qmd": "2.5.3",
    "agent-browser": "0.32.3",
    "defuddle": "0.19.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
